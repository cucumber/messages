<% @enums.each do |enum| -%>
<% ename_ = underscore(enum[:name]) %>
<% ename = enum[:name] %>
<%= ename %>.hpp
#ifndef CUCUMBER_MESSAGES_<%= ename_.upcase %>_HPP
#define CUCUMBER_MESSAGES_<%= ename_.upcase %>_HPP

#include "nlohmann/json_fwd.hpp"
#include <cstdint>
#include <ostream>
#include <string_view>

// Generated code by cpp.enum.hpp.erb

namespace cucumber::messages
{
    enum class <%= ename %> : std::uint_fast8_t
    {
    <%-
    values = enum[:values].map { |value| enum_constant(value) }
    -%>
        <%= values.join(",\n        ") %>,
    };

    [[nodiscard]] std::string_view to_string(<%= ename %> value);

    std::ostream& operator<<(std::ostream& stream, <%= ename %> value);

    void to_json(nlohmann::json& json, const <%= ename %>& msg);
    void from_json(const nlohmann::json& json, <%= ename %>& msg);
}

#endif
<%= ename %>.cpp
#include "cucumber/messages/<%= ename %>.hpp"
#include "nlohmann/json.hpp"
#include "nlohmann/json_fwd.hpp"
#include <iostream>
#include <string_view>
#include <unordered_map>

// Generated code by cpp.enum.hpp.erb

namespace cucumber::messages
{
    std::string_view to_string(<%= ename %> value)
    {
        using map_type = std::unordered_map<<%= ename %>, std::string_view>;

        static const map_type lut = {
<%- enum[:values].each_with_index do |value, index| -%>
            { <%= ename %>::<%= enum_constant(value) %>, "<%= value %>" },
<% end -%>
        };

        return lut.at(value);
    }

    std::ostream& operator<<(std::ostream& stream, <%= ename %> value)
    {
        stream << to_string(value);

        return stream;
    }

    void to_json(nlohmann::json& json, const <%= ename %>& msg)
    {
        json = to_string(msg);
    }

    void from_json(const nlohmann::json& json, <%= ename %>& msg)
    {
        static const std::unordered_map<std::string_view, <%= ename %>> lut = {
<%- enum[:values].each_with_index do |value, index| -%>
            { "<%= value %>", <%= ename %>::<%= enum_constant(value) %> },
<% end -%>
        };

        msg = lut.at(json.get<std::string_view>());
    }
}<%- end -%>
