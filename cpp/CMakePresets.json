{
    "version": 6,
    "configurePresets": [
        {
            "name": "host",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "On",
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "coverage",
            "inherits": "host",
            "cacheVariables": {
                "CUCUMBER_MESSAGES_ENABLE_COVERAGE": "ON",
                "CUCUMBER_MESSAGES_BUILD_TESTS": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "host",
            "configurePreset": "host"
        },
        {
            "name": "coverage",
            "configurePreset": "coverage"
        }
    ],
    "testPresets": [
        {
            "name": "coverage",
            "configurePreset": "coverage"
        }
    ],
    "workflowPresets": [
        {
            "name": "host",
            "steps": [
                {
                    "name": "host",
                    "type": "configure"
                },
                {
                    "name": "host",
                    "type": "build"
                }
            ]
        },
        {
            "name": "coverage",
            "steps": [
                {
                    "name": "coverage",
                    "type": "configure"
                },
                {
                    "name": "coverage",
                    "type": "build"
                },
                {
                    "name": "coverage",
                    "type": "test"
                }
            ]
        }
    ]
}
